# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────────────────────
# Telegram  (leave both blank to disable Telegram delivery)
# ─────────────────────────────────────────────────────────────
# 1. Create a bot via @BotFather  ->  /newbot  ->  copy the token
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceMe
# 2. Add the bot to your group, then get the group's chat id.
#    Easiest: add @RawDataBot to the group and read "chat":{"id":-100...}
#    Group/supergroup ids are negative, e.g. -1001234567890
TELEGRAM_CHAT_ID=-1001234567890
